# ============================================
# Waffler Backend Configuration (Railway)
# ============================================

# Database
# Local dev: SQLite
DATABASE_URL=sqlite:///./waffler_local.db
# Production: PostgreSQL (set on Railway)
# DATABASE_URL=postgresql://user:password@host:5432/waffler

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=dev-secret-change-in-production-12345

# App secret — desktop app must send this in X-App-Secret header
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET=

# OpenAI API key (for Whisper transcription)
OPENAI_API_KEY=

# Replicate API token (for LLM styling with Llama)
REPLICATE_API_TOKEN=

# Stripe (future)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
