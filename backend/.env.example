# Database Configuration
# For local development (SQLite)
DATABASE_URL=sqlite:///./natter_local.db

# For production (PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/natter

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=dev-secret-change-in-production-12345

# Serverless LLM Configuration (for self-hosted LLM styling)
# Get your API key from modal.com or replicate.com
MODAL_API_KEY=
REPLICATE_API_TOKEN=

# Stripe (future)
[STRIPE_SECRET_KEY_REDACTED]...
[STRIPE_WEBHOOK_SECRET_REDACTED]...
