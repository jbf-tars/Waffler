# ============================================
# VoiceFlow Configuration
# Copy this to .env and fill in your key(s)
# ============================================

# --- OpenAI (recommended) ---
# One key does both transcription (Whisper) AND cleanup (GPT-4o-mini)
OPENAI_API_KEY=***REMOVED***

# Prompt style: smart (default), adhd_ramble, or agentic_engineering
PROMPT_STYLE=smart

# Local Whisper: 1 = on-device transcription (requires restart)
# LOCAL_WHISPER=1
