# ============================================
# Waffler Configuration
# Copy this to .env and fill in your values
# ============================================

# --- Hosted mode (production) ---
# Set these to route transcription + styling through the Railway backend.
# Users don't need their own API keys — the backend holds them.
BACKEND_URL=https://your-railway-url.up.railway.app
APP_SECRET=your_shared_app_secret_here

# --- BYOK / dev mode (fallback if BACKEND_URL is not set) ---
# One key does both transcription (Whisper) AND cleanup (GPT-4o-mini)
# OPENAI_API_KEY=your_openai_api_key_here

# Prompt style: smart (default), adhd_ramble, or agentic_engineering
PROMPT_STYLE=smart

# Local Whisper: 1 = on-device transcription (requires restart)
# LOCAL_WHISPER=1
