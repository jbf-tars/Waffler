# ============================================
# Waffler Self-Hosted Configuration (BYOK)
# Copy this to .env and fill in your key(s)
# ============================================
#
# You only need ONE provider key to use Waffler.
# Setting all three gives you maximum rate-limit headroom — Waffler
# picks the fastest available and falls back automatically on errors.

# --- Groq (recommended) ----------------------------------------
# Fastest Whisper transcription AND fastest Llama-style cleanup.
# Generous free tier. Sign up: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here

# --- Cerebras (recommended for cleanup) ------------------------
# Fastest LLM in the world for cleanup (~2200+ tok/s on Qwen 235B).
# Free tier available. Sign up: https://cloud.cerebras.ai
# CEREBRAS_API_KEY=your_cerebras_api_key_here

# --- OpenAI (reliable fallback) --------------------------------
# Whisper transcription + GPT-4.1-mini cleanup. Cheapest at low volume.
# Sign up: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# --- Prompt style ---------------------------------------------
# Only "normal" is exposed in the UI right now. Email mode shipped in
# v3.14.0 and was reverted to "coming soon" in v3.14.6 pending more work;
# the prompts/email.txt file is still in the repo and can be forced via
# this env var if you want to test it, but it's not officially supported.
PROMPT_STYLE=normal

# --- Local Whisper (offline transcription, optional) ----------
# 1 = use on-device transcription instead of cloud APIs.
# Requires `bash install_local_whisper.sh` first.
# LOCAL_WHISPER=1

# --- Code Signing (macOS build only) --------------------------
# Only needed if you're building your own signed/notarised DMG.
# CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# NOTARIZE_TEAM_ID=TEAMID
# NOTARIZE_APPLE_ID=your@email.com
# NOTARIZE_APP_PASSWORD=app-specific-password
