# ============================================
# Waffler Self-Hosted Configuration (BYOK)
# Copy this to .env and fill in your key(s)
# ============================================

# --- OpenAI (recommended) ---
# One key does both transcription (Whisper) AND cleanup (GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# --- Groq (alternative, faster) ---
# GROQ_API_KEY=your_groq_api_key_here

# Prompt style: normal (default)
PROMPT_STYLE=normal

# Local Whisper: 1 = on-device transcription (requires restart)
# LOCAL_WHISPER=1
